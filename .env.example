# Required: Database connection string
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# Required in production: Use a strong random secret
JWT_SECRET="replace-with-strong-random-secret"

# Required: JWT token lifetime
JWT_EXPIRY="7d"

# Required: Server port (set by hosting provider or manually)
PORT=5000

# Required: Comma-separated allowed frontend origins
CORS_ORIGINS="https://edu-pro-frontend.vercel.app,http://localhost:5173"
