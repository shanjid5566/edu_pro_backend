enum Gender {
  MALE
  FEMALE
  OTHER
}



model Profile {
  id          String    @id @default(uuid())
  userId      String    @unique
  address     String?
  dateOfBirth DateTime?
  gender      Gender?
  bio         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}
