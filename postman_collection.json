      "name": "Health",
      "item": [
        {
          "name": "Get Health Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check server health status with detailed information"
          },
          "response": []
        },
        {
          "name": "Ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health/ping",
              "host": ["{{baseUrl}}"],
              "path": ["health", "ping"]
            },
            "description": "Simple ping endpoint"
          },
          "response": []
        }
      ]
    },
