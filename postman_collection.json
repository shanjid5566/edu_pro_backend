  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const autoAuthEnabled = (pm.collectionVariables.get('autoAuthEnabled') || 'true') === 'true';",
          "const envToken = pm.environment.get('token');",
          "const colToken = pm.collectionVariables.get('token');",
          "const token = envToken || colToken || '';",
          "const requestUrl = pm.request.url.toString();",
          "const isPublic = /\\/health(\\/|$)|\\/auth\\/login$|\\/notices(\\/|$)|\\/settings\\/general$/.test(requestUrl);",
          "if (autoAuthEnabled && !isPublic) {",
          "  if (token) pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "}",
          "if (autoAuthEnabled && isPublic && /\\/auth\\/login$/.test(requestUrl)) pm.request.headers.remove('Authorization');"
        ]
      }
    }
  ]
}