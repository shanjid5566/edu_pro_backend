{
  "info": {
    "_postman_id": "edupro-collection",
    "name": "EduPro",
    "description": "EduPro Authentication API testing for all dashboards: Admin, Teacher, Student, Parent",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin Dashboard",
      "item": [
        {
          "name": "Login",
          "item": [
            {
              "name": "Admin Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "var jsonData = pm.response.json();",
                      "if (jsonData.success && jsonData.data && jsonData.data.token) {",
                      "    pm.environment.set('admin_token', jsonData.data.token);",
                      "    pm.environment.set('admin_user_id', jsonData.data.user.id);",
                      "    console.log('✅ Admin token saved');",
                      "} else {",
                      "    console.log('❌ Login failed');",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@edupro.com\",\n  \"password\": \"admin@123\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/v1/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "auth", "login"]
                }
              },
              "response": []
            },
            {
              "name": "Admin Get Profile",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{admin_token}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/v1/auth/profile",
                  "host": ["{{base_url}}"],
                  "path": ["api", "v1", "auth", "profile"]
                }
              },
              "response": []
            }
          ]
        }
      ]
    },
